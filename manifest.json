{
  "manifest_version": 3,
  "name": "PolyOx — NBA Agent",
  "short_name": "PolyOx",
  "version": "2.0.0",
  "description": "Get AI-powered NBA game predictions directly on Polymarket. PolyOx detects matchups, runs deep analysis, and delivers win-probability breakdowns — all paid seamlessly with x402 on Base Sepolia USDC.",
  "homepage_url": "https://polyox.io",
  "action": {
    "default_popup": "popup.html",
    "default_title": "PolyOx Agent",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://polymarket.com/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://api-hoobs.polyox.io/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icon.webp"],
      "matches": ["<all_urls>"]
    }
  ]
}
