{
  "manifest_version": 3,
  "name": "Polyox — Ethereum Wallet Demo",
  "version": "1.0.0",
  "description": "Detect Ethereum wallets, view address & balance, and sign messages.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Polyox Wallet"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "icons": {}
}
