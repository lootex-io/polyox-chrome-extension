{
  "manifest_version": 3,
  "name": "PolyOx",
  "short_name": "PolyOx",
  "version": "1.3.0",
  "author": "PolyOx",
  "description": "Specialized AI agents hunting alpha across verticals.",
  "homepage_url": "https://polyox.io",
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "PolyOx Agent",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://polymarket.com/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "host_permissions": [
    "https://api-hoobs.polyox.io/*",
    "https://polymarket.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icon.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
