{
  "name": "polyox-chrome",
  "version": "1.0.0",
  "description": "PolyOx Chrome extension for Polymarket AI prediction",
  "author": "PolyOx",
  "license": "MIT",
  "homepage": "https://polyox.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/lootex-io/polyox-chrome-extension.git"
  },
  "keywords": [
    "polyox",
    "chrome",
    "extension",
    "web3",
    "ai"
  ],
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/chrome": "^0.1.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.24.0",
    "typescript": "^5.9.3"
  }
}
